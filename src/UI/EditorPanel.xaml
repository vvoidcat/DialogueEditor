<UserControl x:Class="DialogueEditor.Views.EditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogueEditor.Views"
             xmlns:common="clr-namespace:DialogueEditor.UI.CommonControls"
             xmlns:converters="clr-namespace:DialogueEditor.UI.Converters"
             xmlns:controllers="clr-namespace:DialogueEditor.Controllers"
             x:Name="EditorPanelRoot"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <controllers:EditorPanelViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:VisibilityToGridLengthConverter x:Key="VisibilityToGridLengthConverter" DefaultSize="200"/>
    </UserControl.Resources>

    <TabControl BorderBrush="#FFD7E3E9" BorderThickness="0">
        <TabItem Header="TabItem" BorderBrush="#FFD7E3E9" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="3"/>
                    <RowDefinition 
                        x:Name="SettingsRow" 
                        Height="{Binding IsVisibleNodeSettingsPanel, 
                                Mode=TwoWay, 
                                Converter={StaticResource VisibilityToGridLengthConverter}, 
                                ConverterParameter=SettingsRow}"/>
                </Grid.RowDefinitions>

                <TreeView 
                    Grid.Row="0" 
                    BorderBrush="#FFD7E3E9" 
                    Background="#FFF0F0F0" 
                    ItemsSource="{Binding Nodes}">

                    <TreeView.ItemContainerStyle>
                        <StaticResource ResourceKey="DialogueNodeItemStyle"/>
                    </TreeView.ItemContainerStyle>

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding DisplayName}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>

                </TreeView>

                <common:ShowHideButtonControl x:Name="NodeSettingsToggleButton"
                    Grid.Row="1" 
                    Command="{Binding toggleHideNodeSettingsCommand}" 
                    Orientation="Horizontal" 
                    Direction="Up"
                    IsOpen="{Binding IsVisibleNodeSettingsPanel}"/>

                <common:TargetedGridSplitter 
                    Grid.Row="2" 
                    Height="3" 
                    FirstTargetOrder="0" 
                    SecondTargetOrder="3" 
                    MinTargetSize="200" 
                    Orientation="Horizontal"
                    Style="{StaticResource TargetedGridSplitterStyle}"
                    IsEnabled="{Binding IsVisibleNodeSettingsPanel}"/>
                
                <GroupBox Grid.Row="3" Header="Node Settings" />
                
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
