<UserControl x:Class="DialogueEditor.Views.VariablesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogueEditor.Views"
             xmlns:common="clr-namespace:DialogueEditor.UI.CommonControls"
             xmlns:controllers="clr-namespace:DialogueEditor.Controllers"
             x:Name="VariablesPanelRoot"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <controllers:VariablesPanelViewModel/>
    </UserControl.DataContext>

    <GroupBox Header="Configuration Variables" BorderBrush="#FFD7E3E9" Name="ConfigurationVariablesGroupBox" Visibility="Visible">
        <StackPanel Margin="2">
            <Grid Height="20" Margin="0 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" MinWidth="100" Height="20" Text="search..."/>
            </Grid>

            <Button Content="New Variable" Margin="5"/>

            <ListBox BorderThickness="0">
                <TextBox Text="Name String Value" Height="50"/>
                <TextBox Text="Name2 Int Values" Height="50"/>
            </ListBox>
        </StackPanel>
    </GroupBox>
</UserControl>
