<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:common="clr-namespace:DialogueEditor.UI.CommonControls">

    <Style x:Key="ShowHideButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="White"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" Value="Horizontal">
                <Setter Property="Height" Value="20"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" Value="Vertical">
                <Setter Property="Width" Value="20"/>
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Direction, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="Left"/>
                    <Condition Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Content" Value="&lt;"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Direction, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="Left"/>
                    <Condition Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Content" Value="&gt;"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Direction, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="Right"/>
                    <Condition Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Content" Value="&gt;"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Direction, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="Right"/>
                    <Condition Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Content" Value="&lt;"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Direction, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="Up"/>
                    <Condition Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Content" Value="^"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Direction, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="Up"/>
                    <Condition Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Content" Value="v"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Direction, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="Down"/>
                    <Condition Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Content" Value="v"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Direction, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="Down"/>
                    <Condition Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType={x:Type common:ShowHideButtonControl}}}" 
                       Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Content" Value="^"/>
            </MultiDataTrigger>

        </Style.Triggers>
    </Style>
    
</ResourceDictionary>