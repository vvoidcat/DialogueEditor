<UserControl x:Class="DialogueEditor.Views.Common.ShowHideButtonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogueEditor.Views.Common"
             mc:Ignorable="d" 
             x:Name="ShowHideButtonControlRoot"
             d:DesignHeight="450" d:DesignWidth="800">

    <Button  
        Width="20" 
        BorderThickness="0" 
        Background="White" 
        Content="^" 
        Command="{Binding ElementName=ShowHideButtonControlRoot, Path=Command}"/>

</UserControl>
