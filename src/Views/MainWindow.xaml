<Window x:Class="DialogueEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DialogueEditor.Views"
        xmlns:common="clr-namespace:DialogueEditor.Views.Common"
        xmlns:controllers="clr-namespace:DialogueEditor.Controllers"
        mc:Ignorable="d"
        Title="DialogueEditor" MinHeight="500" MinWidth="1000">

    <Window.DataContext>
        <controllers:MainWindowViewModel/>
    </Window.DataContext>


    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="12*"/>
            <RowDefinition Height="2"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <Label DockPanel.Dock="Left" Height="20" Padding="0" Margin="10 0" Content="bla bla bla Config name / JSON" Foreground="LightGray"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <RadioButton Content="Dark" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition>    <!-- CONFIGS -->
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="*" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding isVisibleConfigsPanel}" Value="False">
                                    <Setter Property="Width" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="20"/>  <!-- CONFIGS TOGGLE -->
                <ColumnDefinition>    <!-- VARIABLES -->
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="*" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding isVisibleVariablesPanel}" Value="False">
                                    <Setter Property="Width" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="20"/>  <!-- VARIABLES TOGGLE -->
                <ColumnDefinition Width="3*"/>  <!-- WORKING AREA -->
                <ColumnDefinition Width="20"/>  <!-- DLG FILES TOGGLE -->
                <ColumnDefinition>    <!-- DLG FILES -->
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="*" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding isVisibleDlgFilesPanel}" Value="False">
                                    <Setter Property="Width" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- PRESET CONFIGURATIONS -->
            <local:ConfigurationsPanel Grid.Column="0"/>
            <common:ShowHideButtonControl Grid.Column="1" Command="{Binding toggleHideConfigsCommand}"/>

            <!-- GLOBAL VARIABLES -->
            <local:VariablesPanel Grid.Column="2" />
            <common:ShowHideButtonControl Grid.Column="3" Command="{Binding toggleHideVariablesCommand}"/>

            <!-- WORKING AREA -->
            <local:MainArea Grid.Column="4"/>

            <!-- DLG FILES -->
            <common:ShowHideButtonControl Grid.Column="5" Command="{Binding toggleHideDlgFilesCommand}"/>
            <local:DialogueFilesPanel Grid.Column="6"/>

        </Grid>
        
    </Grid>
</Window>
